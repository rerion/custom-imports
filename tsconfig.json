{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2024"],
    "types": ["node"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "outDir": "dist",
    "rootDir": "src",

    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "esModuleInterop": false,
    "skipLibCheck": true,

    "resolveJsonModule": true
  },
  "include": ["src"]
}