{
  "name": "custom-imports",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "bin": {
    "custom-imports": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:packages": "pnpm -r --filter './packages/*' build",
    "dev": "tsx src/cli.ts",
    "test": "pnpm build && pnpm build:packages && pnpm build:test-plugins && vitest run",
    "test:unit": "vitest run --project unit",
    "test:build-e2e": "pnpm build && pnpm build:test-plugins && vitest run --project build-e2e",
    "test:build-e2e:update": "pnpm build && pnpm build:test-plugins && UPDATE_EXPECTED=1 vitest run --project build-e2e",
    "test:build-e2e:cleanup": "tsx tests/build-e2e/cleanup-fixtures.ts",
    "test:watch-e2e": "pnpm build && pnpm build:test-plugins && vitest run --project watch-e2e",
    "test:watch-e2e:update": "pnpm build && pnpm build:test-plugins && UPDATE_EXPECTED=1 vitest run --project watch-e2e",
    "test:watch-e2e:cleanup": "tsx tests/watch-e2e/cleanup-fixtures.ts",
    "test:watch": "vitest",
    "build:test-plugins": "pnpm -r --filter '@test/*' build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3",
    "web-tree-sitter": "^0.26.10"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "memfs": "^4.17.2",
    "tsx": "^4.22.4",
    "vitest": "^3.2.4"
  }
}
